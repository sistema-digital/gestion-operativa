# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""

# VITE_DATA_DEV: Toggle for generating local mock data instead of real Supabase data.
# Set to "true" to avoid Supabase calls and use dynamic mock data in local dev.
# In production, leave empty or false to ensure real data is used.
VITE_DATA_DEV="false"

# Supabase Configurations
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

VITE_SUPABASE_RATINGS_URL=your_supabase_ratings_url
VITE_SUPABASE_RATINGS_ANON_KEY=your_supabase_ratings_anon_key

VITE_SUPABASE_COMPRAS_URL=your_supabase_compras_url
VITE_SUPABASE_COMPRAS_ANON_KEY=your_supabase_compras_anon_key

VITE_SUPABASE_EQUIPOS_URL=your_supabase_equipos_url
VITE_SUPABASE_EQUIPOS_ANON_KEY=your_supabase_equipos_anon_key